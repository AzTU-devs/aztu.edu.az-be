# ========================
# DATABASE (local docker)
# ========================
POSTGRES_USER=aztu_edu_az
POSTGRES_PASSWORD=change_me
POSTGRES_DB=aztu_edu_az_db

# ========================
# DATABASE
# ========================
# Production:
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
# Local docker:
# DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres-app:5432/${POSTGRES_DB}
DATABASE_URL=postgresql://user:password@localhost:5432/aztu_edu_az_db

# ========================
# JWT (REQUIRED, min 32 chars)
# ========================
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace_with_64_hex_chars_from_secrets_token_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ========================
# ADMIN SEED (first-run only)
# ========================
ADMIN_SEED_USERNAME=admin
ADMIN_SEED_PASSWORD=change_me

# ========================
# APP
# ========================
ENVIRONMENT=production
# JSON list. In development, http://localhost:3000 and :5173 are auto-added.
ALLOWED_ORIGINS=["https://aztu.edu.az","https://www.aztu.edu.az"]
ALLOW_PRIVATE_NETWORK_ACCESS=false

# ========================
# REDIS (required for rate limiter across workers)
# ========================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ========================
# THIRD-PARTY APIs
# ========================
OPEN_AI_KEY=
SCOPUS_API_KEY=

# ========================
# VISITOR ANALYTICS
# ========================
# Salt for the stored visitor hash. Leave blank to derive it from JWT_SECRET_KEY.
# Set it explicitly if you ever rotate JWT_SECRET_KEY, otherwise the rotation
# changes every visitor hash and that day's unique count is counted twice.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
VISIT_HASH_SALT=
# How long the per-visitor hashes are kept. The daily view counters are never
# purged — they are one row per day and hold no visitor identifier.
SITE_VISIT_RETENTION_DAYS=400

# ========================
# DOCS
# ========================
# Leave blank to disable Swagger / ReDoc / openapi.json. Otherwise set a long
# random token; docs will be exposed at /docs-<token>.
DOCS_TOKEN=
